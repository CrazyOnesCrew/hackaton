# =============================================================================
# PAAG — production environment template
#
# Copy to `.env.production` and fill in real values (never commit secrets):
#   cp .env.production.example .env.production
#
# Then start the stack:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# All values below are placeholders. Replace every CHANGE_ME / empty secret.
# =============================================================================

# ----- Public routing (Caddy) -----
# Hostname used in docs and client URLs (no scheme).
DOMAIN=localhost
# Caddy site address:
#   Local HTTP smoke test:  http://localhost
#   Production with TLS:    app.example.com   (no scheme — Caddy obtains certificates)
CADDY_SITE=http://localhost
HTTP_PORT=80
HTTPS_PORT=443

# ----- PostgreSQL -----
POSTGRES_USER=paag
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=paag_production

# ----- Rails API -----
# Contents of apps/api/config/master.key (from the machine that created credentials).
# Required to boot the production image. Generate credentials in apps/api if missing:
#   cd apps/api && bin/rails credentials:edit
RAILS_MASTER_KEY=CHANGE_ME_RAILS_MASTER_KEY

APP_NAME=PAAG
# Public URL of the student web app (browser-facing), used for LTI redirects.
APP_WEB_URL=http://localhost

# AI provider (optional until AI features are enabled). Keep calls behind Rails.
ANTHROPIC_API_KEY=
AI_FEEDBACK_ENABLED=true

# Path inside the api/worker containers (named volume `lti_keys`).
LTI_TOOL_PRIVATE_KEY_PATH=/rails/config/lti_keys/tool_private.pem

# Optional seed password for first boot (db:prepare / seeds). Leave empty to skip custom seeds.
SEED_PASSWORD=

# ----- Portal (Next.js) -----
# Server-side URL used by the portal container to reach Rails on the compose network.
# Thruster listens on port 80 inside the api container.
PORTAL_RAILS_API_URL=http://api:80
# Must match the Caddy /portal* route.
NEXT_BASE_PATH=/portal
# Optional break-glass secret for admin helper routes.
ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET

# ----- Student web (Expo export, baked at image build time) -----
# Browser-facing origin of the API (no trailing slash, no /api/v1).
# Local smoke: http://localhost
# Production:  https://app.example.com
EXPO_PUBLIC_API_URL=http://localhost
EXPO_PUBLIC_VAR_NUMBER=10
EXPO_PUBLIC_VAR_BOOL=true
