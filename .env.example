# Root-level environment for the Docker Compose dev stack (docker-compose.yml).
# Copy to .env and adjust as needed:  cp .env.example .env
#
# .env is gitignored. Never commit real secrets. These are LOCAL DEV defaults
# only — do not reuse them in production.

# ----- Ports (host side) -----
# Rails API, reachable from the host at http://localhost:<API_PORT>/
API_PORT=3000
# PostgreSQL published to the host (for DBeaver/psql). 5433 by default so it
# does not collide with a PostgreSQL already listening on 5432.
POSTGRES_HOST_PORT=5433

# ----- PostgreSQL (container) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_development
