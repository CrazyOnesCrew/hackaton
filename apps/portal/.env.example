# =============================================================================
# Portal — Environment Variables
#
# The portal has no local database or auth provider of its own — Rails
# (apps/api) is the single source of truth for users and sessions. Copy this
# file to .env.local and point RAILS_API_URL at your local Rails server.
#   cp .env.example .env.local
# =============================================================================

# ----- Rails API -----
# Base URL of the Rails API this portal authenticates against.
# Outside Docker (portal on the host): http://127.0.0.1:3000 (or http://localhost:3000)
# Inside Docker Compose: http://api:3000 (set automatically by docker-compose.yml)
RAILS_API_URL="http://127.0.0.1:3000"

# ----- PAAG mock API -----
# When unset: mock is used outside production. Set "false" to call Rails.
# NEXT_PUBLIC_USE_MOCK_API="true"

# ----- Admin / API secrets -----
# Token for break-glass routes (e.g. /api/seed or /api/clear), if added later.
ADMIN_SECRET="change-me"
