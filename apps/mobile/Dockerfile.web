# syntax=docker/dockerfile:1
# Multi-stage production image for the Expo web (student) app:
# 1) Node + pnpm runs `expo export --platform web`
# 2) nginx serves the static export

ARG NODE_VERSION=20

FROM node:${NODE_VERSION}-alpine AS builder

RUN corepack enable && corepack prepare pnpm@10.12.3 --activate

WORKDIR /app

# Skip husky / git hooks inside the image build.
ENV CI=1 \
    HUSKY=0 \
    NEXT_TELEMETRY_DISABLED=1

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

# Public env baked into the static export (must be absolute URLs reachable by browsers).
ARG EXPO_PUBLIC_APP_ENV=production
ARG EXPO_PUBLIC_API_URL
ARG EXPO_PUBLIC_VAR_NUMBER=10
ARG EXPO_PUBLIC_VAR_BOOL=true

ENV EXPO_PUBLIC_APP_ENV=$EXPO_PUBLIC_APP_ENV \
    EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL \
    EXPO_PUBLIC_VAR_NUMBER=$EXPO_PUBLIC_VAR_NUMBER \
    EXPO_PUBLIC_VAR_BOOL=$EXPO_PUBLIC_VAR_BOOL

RUN test -n "$EXPO_PUBLIC_API_URL" || (echo "EXPO_PUBLIC_API_URL build-arg is required" && exit 1)

RUN pnpm exec expo export --platform web

FROM nginx:1.27-alpine AS runner

COPY nginx.web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=5 \
  CMD wget -qO- http://127.0.0.1:80/healthz || exit 1

CMD ["nginx", "-g", "daemon off;"]
