# Application Environment (development | preview | production)
EXPO_PUBLIC_APP_ENV=development

# Rails API base URL (no trailing /api/v1 — the client adds that path)
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# Use mock API data without Rails (optional)
EXPO_PUBLIC_USE_MOCK_API=false

# Example Variables
EXPO_PUBLIC_VAR_NUMBER=10
EXPO_PUBLIC_VAR_BOOL=true
