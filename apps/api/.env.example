# Copy to .env and adjust for your machine. .env is gitignored — local only.
# Never commit real secrets.
#
# Most contributors need nothing here at all: the defaults in
# config/database.yml work with a standard local PostgreSQL.

# ----- Application -----
# Surfaced by GET /api/v1/info.
APP_NAME=AI-First Project Template

# ----- Database -----
# Only set what differs from the defaults in config/database.yml.
#
# Uncomment and change if your local PostgreSQL isn't on the standard port —
# e.g. when another project's Postgres (often via Docker) already occupies
# 5432. Check with `lsof -nP -iTCP:5432 -sTCP:LISTEN` if db:prepare/db:seed
# fails with "no password supplied" or "connection refused".
# DB_PORT=5432

# DB_HOST=127.0.0.1
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_NAME=template_development
# DB_TEST_NAME=template_test

# Password for the demo seed users (db/seeds.rb). Change it for real projects.
# SEED_PASSWORD=Password123

# ----- AI provider -----
# Required only when you enable AI features. Keep provider calls behind Rails.
ANTHROPIC_API_KEY=

# ----- Production only -----
# RAILS_MASTER_KEY=
